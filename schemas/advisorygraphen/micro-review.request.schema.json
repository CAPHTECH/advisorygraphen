{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/advisorygraphen/micro-review.request.schema.json",
  "title": "AdvisoryGraphen Micro Review Request v1",
  "description": "Agent-authored, self-classified claims for `micro review`. The command enforces structural honesty over these classifications; it does not classify prose itself.",
  "type": "object",
  "required": ["schema", "claims"],
  "properties": {
    "schema": {
      "const": "advisorygraphen.micro_review.request.v1"
    },
    "answer_id": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text", "classification"],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "classification": {
            "type": "string",
            "enum": [
              "test_backed",
              "source_backed",
              "assumption",
              "unsupported_strong_claim",
              "unsupported"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_surface": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "alternative_hypotheses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "alternative": {
                  "type": "string"
                },
                "falsifier": {
                  "type": "string"
                }
              }
            }
          },
          "missing_checks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
